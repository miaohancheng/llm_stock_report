# ============================
# Required
# ============================
TAVILY_API_KEY=
BRAVE_API_KEY=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ============================
# Optional
# ============================
TELEGRAM_MESSAGE_THREAD_ID=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
# openai | gemini | ollama
LLM_PROVIDER=openai
# zh | en
REPORT_LANGUAGE=zh
# GitHub Pages default language (zh | en)
PAGES_DEFAULT_LANGUAGE=zh

# Runtime guards
MAX_STOCKS_PER_RUN=30
DETAIL_MESSAGE_CHAR_LIMIT=3500
MODEL_EXPIRE_DAYS=8
MARKET_INDEX_FETCH_ENABLED=true

# Universe overrides (optional)
# If set, env overrides config/universe.yaml.
# STOCK_LIST=600519,000001              # legacy: CN list only
STOCK_LIST_CN=SH600519,SZ000001,SZ300750
STOCK_LIST_US=AAPL,MSFT,NVDA
STOCK_LIST_HK=HK00700,HK03690,HK09988
# Optional custom universe file path
# UNIVERSE_FILE=/abs/path/universe.yaml

# Training/data window
TRAINING_WINDOW_DAYS=730
FEATURE_WARMUP_DAYS=60
HISTORY_PRUNE_BUFFER_DAYS=60
INCREMENTAL_OVERLAP_DAYS=7

# Fetch retry (anti-scraping resilience)
FETCH_MAX_RETRIES=5
FETCH_RETRY_BASE_DELAY_SECONDS=15.0
FETCH_RETRY_MAX_DELAY_SECONDS=300.0
FETCH_RETRY_JITTER_SECONDS=2.0

# LLM retry (handle 429/rate limit and transient upstream errors)
LLM_MAX_RETRIES=6
LLM_RETRY_BASE_DELAY_SECONDS=5.0
LLM_RETRY_MAX_DELAY_SECONDS=120.0
LLM_RETRY_JITTER_SECONDS=1.0

# Paths (relative to project root)
OUTPUTS_ROOT=outputs
MODELS_ROOT=models
QLIB_DATA_ROOT=qlib_data

# Logging
LOG_LEVEL=INFO
